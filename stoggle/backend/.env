# OpenAI API Key (LLM 요약 · 관계 추출)
OPENAI_API_KEY=sk-...

# DART 공시 API Key (https://opendart.fss.or.kr)
DART_API_KEY=

# 데이터베이스 URL (기본값: SQLite)
DATABASE_URL=sqlite:///./stoggle.db

# Redis (Celery 브로커, 선택사항)
REDIS_URL=redis://localhost:6379/0

# 서버 설정
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS 허용 출처 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000
